# Docmee Discord status bot — secrets & channel config.
# Copy this file to ".env" (same folder) and fill in the values.
# .env is gitignored and must never be committed.

# Bot token from https://discord.com/developers/applications
#   -> your app -> "Bot" tab -> "Reset Token" -> Copy
DISCORD_BOT_TOKEN=

# Channel IDs (Discord -> User Settings -> Advanced -> Developer Mode ON,
# then right-click each channel -> "Copy Channel ID").
# Technical digest channel (e.g. #docmee-eng):
DISCORD_CHANNEL_TECH=
# Plain-language channel for non-technical colleagues (e.g. #docmee-team):
DISCORD_CHANNEL_TEAM=
# Live dashboard channel (e.g. #docmee-dashboard). One message is edited in
# place each run to stay a single always-current panel. Leave blank to disable.
DISCORD_CHANNEL_DASHBOARD=
