    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@docmee/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "pino-pretty": "^11.2.0",
