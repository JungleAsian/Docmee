{
  "name": "@docmee/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openapi.yaml": "./openapi.yaml"
  },
  "files": ["dist", "openapi.yaml"],
  "scripts": {
    "generate": "openapi-typescript ./openapi.yaml -o ./src/generated/openapi.gen.ts",
    "build": "pnpm generate && tsup",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "pnpm generate && tsc --noEmit"
  },
  "devDependencies": {
    "@docmee/config": "workspace:*",
    "eslint": "^9.9.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
